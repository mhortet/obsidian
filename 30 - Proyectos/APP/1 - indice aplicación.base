views:
  - type: table
    name: Tabla
    filters:
      and:
        - file.tags.containsAny("app")
    groupBy:
      property: tags
      direction: ASC
    order:
      - file.name
      - tags
      - Creado
  - type: table
    name: Vista
  - type: cards
    name: Vista 2
    imageAspectRatio: 1
